# Optional. Leave unset for normal web development, where Vite proxies /api to the
# local API. Set this for Capacitor/native builds so the bundled app can reach a
# hosted backend instead of capacitor://localhost.
VITE_API_BASE_URL=https://api.example.com/api/v1

# Plant Buddy gamification is a post-release feature — disabled until set to true.
# Also set ENABLE_PLANT_BUDDY=true in the root .env to re-enable the API routes.
# VITE_ENABLE_PLANT_BUDDY=true
