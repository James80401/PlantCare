# Copy to .env.production on the server. Never commit the populated file.

# Database (Compose-local PostgreSQL)
POSTGRES_USER=plantcare
POSTGRES_PASSWORD=replace-with-strong-database-password
POSTGRES_DB=plantcare
DATABASE_URL=postgresql://plantcare:replace-with-strong-database-password@postgres:5432/plantcare?schema=public

# Authentication and public origins
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-different-rand-hex-32
JWT_REFRESH_EXPIRES_IN=30d
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# Release identity (the deployment script sets APP_COMMIT_SHA)
APP_VERSION=0.0.0

# Existing feature gates stay closed unless separately authorized
ENABLE_PLANT_BUDDY=false
ENABLE_PREMIUM_BILLING=false
ENABLE_SWAGGER=false
ALL_USERS_PREMIUM=false
SEED_DEMO_DATA=false

# AI and plant integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODERATION_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
PLANTNET_API_KEY=
PLANTNET_MIN_CONFIDENCE=
PERENUAL_API_KEY=
HF_API_TOKEN=

# SMTP (required when registration approval is enabled)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
REGISTRATION_REQUIRES_ADMIN_APPROVAL=true
ADMIN_EMAILS=you@example.com

# Push: prefer Firebase HTTP v1 credentials
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional file-based alternatives, only when mounted into the API container
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
FCM_SERVER_KEY=

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Existing billing integration remains disabled until a separate activation decision
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM=
PREMIUM_PRICE_LABEL=
PREMIUM_TRIAL_DAYS=14

# Existing error reporting remains disabled without a DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0
