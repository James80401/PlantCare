# Copy to .env.production on your server (never commit .env.production).
# Used with: docker compose -f docker-compose.production.yml --env-file .env.production up -d --build
#
# Put HTTPS reverse proxy (Caddy/nginx) in front:
#   https://api.yourdomain.com  -> api:3001
#   https://app.yourdomain.com  -> web:80

# --- Required ---
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-different-rand-hex-32

# Public URLs (must match what users open in browser / emails)
FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com
# Baked into web Docker image at build time
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# Postgres (managed DB URL, or leave default for compose-internal postgres)
# DATABASE_URL=postgresql://user:pass@your-db-host:5432/plantcare?schema=public

# --- Recommended for testers ---
ALL_USERS_PREMIUM=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# --- Push (Plant Buddy + task reminders) ---
# Prefer FCM HTTP v1 (Firebase service account):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Or: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Legacy (deprecated for new Firebase projects):
# FCM_SERVER_KEY=
# Capacitor mobile origins (https://localhost, capacitor://localhost) are allowed automatically.

# --- Optional ---
# PLANTNET_API_KEY=
# PERENUAL_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PREMIUM=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_PUBLIC_URL=
