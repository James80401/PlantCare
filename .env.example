# SQLite (default local dev — no Docker required)
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL (production / Docker): postgresql://plantcare:plantcare@localhost:5433/plantcare?schema=public
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3001
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
# Comma-separated browser origins (production). Mobile Capacitor origins are added automatically.
# CORS_ORIGINS="https://app.example.com"

# Optional frontend/mobile API base URL. For normal web dev, leave unset so Vite
# proxies /api to the local API. For native builds, also copy apps/web/.env.example
# to apps/web/.env.local and point VITE_API_BASE_URL at a reachable backend.
# VITE_API_BASE_URL=https://api.example.com/api/v1

# Gmail SMTP (dev) — signup verification + password reset
# Create an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Optional integrations (MVP works with mocks when unset)
PERENUAL_API_KEY=
PLANTNET_API_KEY=
# Reject identifications below this confidence (0–1); default 0.10
# PLANTNET_MIN_CONFIDENCE=0.10
HF_API_TOKEN=
# OpenAI (ChatGPT) — powers Dr. Plant with vision + detailed advice (recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Vision model for image moderation (is-plant / is-explicit); default gpt-4o-mini
# OPENAI_MODERATION_MODEL=gpt-4o-mini
# Optional: Azure OpenAI or compatible API
OPENAI_BASE_URL=https://api.openai.com/v1
# Dr. Plant AI usage caps (per user). Defaults shown.
# AI_RATE_LIMIT_WINDOW_MINUTES=60
# AI_RATE_LIMIT_MAX_CALLS=30
# AI_RATE_LIMIT_PAUSE_HOURS=12
# Optional fallback only — Open-Meteo is used by default (no key required)
OPENWEATHER_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM=
PREMIUM_PRICE_LABEL="$4.99/month"
PREMIUM_TRIAL_DAYS=14
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FIREBASE_PROJECT_ID=
# FCM HTTP v1 (preferred): service account JSON path or inline credentials
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# Legacy FCM server key (fallback if v1 credentials are not set)
FCM_SERVER_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_URL=
UPLOAD_DIR=./apps/api/uploads
ALL_USERS_PREMIUM=true
# Allow POST /buddy/dev/* scheduler triggers in production (default: dev only)
# ENABLE_DEV_ROUTES=true
