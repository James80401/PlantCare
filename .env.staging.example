# Copy to .env.staging and adjust secrets before: npm run staging:up

JWT_SECRET=staging-change-me-use-openssl-rand
JWT_REFRESH_SECRET=staging-change-me-refresh-secret

# Must match the URL testers open in the browser
FRONTEND_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# Baked into the web image at build time — must be reachable from the user's browser
VITE_API_BASE_URL=http://localhost:3001/api/v1

ALL_USERS_PREMIUM=true

# Optional — real push when devices register via POST /devices
# FCM_SERVER_KEY=

# Optional — copy from .env if you want Dr. Plant / email in staging
# OPENAI_API_KEY=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=
