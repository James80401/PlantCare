// Docker staging / production — keep in sync with schema.prisma (datasource only differs).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  PREMIUM
}

enum TaskType {
  WATER
  FERTILIZE
  PRUNE
  MIST
  PH_TEST
  PEST_CONTROL
  REPOT
  ROTATE
  CLEAN_LEAVES
  INSPECT_PESTS
  CHECK_MOISTURE
  HEALTH_CHECK
}

enum TaskStatus {
  PENDING
  DONE
  SKIPPED
}

enum PotSize {
  SMALL
  MEDIUM
  LARGE
}

enum PlantLifeStage {
  SEED
  SPROUT
  SEEDLING
  YOUNG_PLANT
  ESTABLISHED
  MATURE
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum AccountApprovalStatus {
  APPROVED
  PENDING
  REJECTED
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  passwordHash          String
  name                  String?
  planTier              PlanTier       @default(FREE)
  stripeCustomerId      String?
  latitude              Float?
  longitude             Float?
  locationLabel         String?
  timezone              String         @default("America/New_York")
  temperatureUnit       String         @default("C")
  notifyPush            Boolean        @default(true)
  notifyEmail           Boolean        @default(true)
  notifySms             Boolean        @default(false)
  quietHoursStart       Int?
  quietHoursEnd         Int?
  identifyCountThisMonth Int           @default(0)
  identifyCountResetAt  DateTime       @default(now())
  emailVerified         Boolean        @default(true)
  accountApprovalStatus AccountApprovalStatus @default(APPROVED)
  emailVerificationToken String?       @unique
  emailVerificationExpires DateTime?
  passwordResetToken    String?        @unique
  passwordResetExpires  DateTime?
  aiPausedUntil         DateTime?
  experienceLevel       String?
  defaultLightLevel     String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  plants                Plant[]
  subscriptions         Subscription[]
  notificationLogs      NotificationLog[]
  deviceTokens          DeviceToken[]
  taskFeedback          TaskFeedback[]
  weatherAdviceCache    WeatherAdviceCache?
  ownedGardens          Garden[]           @relation("GardenOwner")
  gardenMemberships     GardenMember[]
  communityPosts        CommunityPost[]
  comments              Comment[]
  postLikes             PostLike[]
  activityEvents        ActivityEvent[]
  buddy                 Buddy?
  plantMilestones       PlantMilestone[]
  refreshTokens         RefreshToken[]
  aiUsageEvents         AiUsageEvent[]
  adminAuditLogs        AdminAuditLog[] @relation("AdminAuditActor")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  actor        User?    @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail   String?
  action       String
  method       String
  path         String
  targetUserId String?
  requestId    String?
  statusCode   Int
  outcome      String
  durationMs   Int
  ip           String?
  userAgent    String?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@index([outcome, createdAt])
}

model AiUsageEvent {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature        String
  plantId        String?
  conversationId String?
  promptChars    Int      @default(0)
  imageCount      Int      @default(0)
  status         String
  reason         String?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([status, createdAt])
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  familyId    String
  parentId    String?
  replacedBy  String?
  revokedAt   DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  userAgent   String?
  ip          String?

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model WeatherAdviceCache {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fetchedAt    DateTime
  localDateKey String
  locationKey  String
  payload      String
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planName         String
  status           SubscriptionStatus @default(ACTIVE)
  stripeId         String?
  startDate        DateTime           @default(now())
  endDate          DateTime?
  createdAt        DateTime           @default(now())
}

model PlantSpecies {
  id                String   @id @default(cuid())
  perenualId        Int?     @unique
  commonName        String
  scientificName    String?
  sunlight          String?
  wateringFreqDays  Int      @default(7)
  toxicity          String?
  phMin             Float?
  phMax             Float?
  careNotes         String?
  defaultImageUrl   String?
  metadataJson      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  plants            Plant[]
  careGuides        CareGuide[]
  communityPosts    CommunityPost[]

  @@index([commonName])
}

model CareGuide {
  id           String          @id
  taskType     TaskType
  speciesId    String?
  species      PlantSpecies?   @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  title        String
  summary      String
  sectionsJson String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  images       CareGuideImage[]

  @@unique([taskType, speciesId])
  @@index([taskType])
}

model CareGuideImage {
  id          String    @id @default(cuid())
  careGuideId String
  careGuide   CareGuide @relation(fields: [careGuideId], references: [id], onDelete: Cascade)
  imageKey    String
  caption     String
  altText     String
  sortOrder   Int       @default(0)

  @@index([careGuideId])
}

model Plant {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  gardenId    String
  garden      Garden       @relation("GardenPlants", fields: [gardenId], references: [id], onDelete: Cascade)
  speciesId   String
  species     PlantSpecies @relation(fields: [speciesId], references: [id])
  nickname    String?
  location    String?
  potSize     PotSize      @default(MEDIUM)
  lifeStage   PlantLifeStage @default(ESTABLISHED)
  approximateAgeMonths Int?
  datePlanted DateTime?
  imageUrl    String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tasks       Task[]
  journalEntries JournalEntry[]
  diagnoses              Diagnosis[]
  diagnosisConversations DiagnosisConversation[]
  shares                 PlantShare[]
  milestones             PlantMilestone[]

  @@index([userId])
  @@index([gardenId])
}

model PlantMilestone {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plantId      String?
  plant        Plant?   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  milestoneKey String
  title        String
  unlockedAt   DateTime @default(now())

  @@unique([userId, milestoneKey])
  @@index([userId])
  @@index([plantId])
}

model Task {
  id                String     @id @default(cuid())
  plantId           String
  plant             Plant      @relation(fields: [plantId], references: [id], onDelete: Cascade)
  gardenId          String?
  garden            Garden?    @relation("GardenTasks", fields: [gardenId], references: [id], onDelete: Cascade)
  taskType          TaskType
  dueDate           DateTime
  completedAt       DateTime?
  status            TaskStatus @default(PENDING)
  notifiedAt        DateTime?
  sourceDiagnosisId String?
  sourceDiagnosis   Diagnosis? @relation("DiagnosisFollowUpTasks", fields: [sourceDiagnosisId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  feedback          TaskFeedback[]

  @@index([dueDate, status])
  @@index([plantId])
  @@index([gardenId, status])
  @@index([sourceDiagnosisId])
}

model TaskFeedback {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  reason    String
  note      String?
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId, createdAt])
  @@index([reason])
}

model JournalEntry {
  id        String   @id @default(cuid())
  plantId   String
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  photoUrl  String?
  notes     String?
  heightCm  Float?
  widthCm   Float?
  leafCount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([plantId])
}

model Diagnosis {
  id            String   @id @default(cuid())
  plantId       String
  plant         Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  imageUrl      String?
  symptomsText  String?
  resultLabel   String
  confidence    Float?
  adviceText    String?
  source        String   @default("rules")
  detailJson    String?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  followUpTasks Task[]   @relation("DiagnosisFollowUpTasks")

  @@index([plantId])
  @@index([plantId, resolved])
}

model DiagnosisConversation {
  id        String             @id @default(cuid())
  plantId   String
  plant     Plant              @relation(fields: [plantId], references: [id], onDelete: Cascade)
  userId    String
  title     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  messages  DiagnosisMessage[]

  @@index([plantId])
  @@index([userId])
}

model DiagnosisMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   DiagnosisConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  imageUrl       String?
  createdAt      DateTime              @default(now())

  @@index([conversationId])
}

model NotificationLog {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  message   String
  status    String              @default("sent")
  createdAt DateTime            @default(now())

  @@index([userId])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  platform  String
  createdAt DateTime @default(now())

  @@unique([userId, token])
}

model Garden {
  id        String         @id @default(cuid())
  name      String
  location  String?
  ownerId   String
  owner     User           @relation("GardenOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   GardenMember[]
  homePlants Plant[]       @relation("GardenPlants")
  tasks     Task[]         @relation("GardenTasks")
  plants    PlantShare[]
  invites   CareInvite[]
  activity  ActivityEvent[]

  @@index([ownerId])
}

model GardenMember {
  id       String   @id @default(cuid())
  gardenId String
  garden   Garden   @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String
  joinedAt DateTime @default(now())

  @@unique([gardenId, userId])
  @@index([userId])
}

model PlantShare {
  id          String  @id @default(cuid())
  gardenId    String
  garden      Garden  @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  plantId     String
  plant       Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  canComplete Boolean @default(true)
  canJournal  Boolean @default(false)

  @@unique([gardenId, plantId])
  @@index([plantId])
}

model CareInvite {
  id         String    @id @default(cuid())
  gardenId   String
  garden     Garden    @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  email      String?
  token      String    @unique
  role       String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([gardenId])
  @@index([email])
}

model CommunityPost {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  speciesId String?
  species   PlantSpecies? @relation(fields: [speciesId], references: [id], onDelete: SetNull)
  imageUrl  String?
  tagsJson  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comments  Comment[]
  likes     PostLike[]

  @@index([authorId])
  @@index([createdAt])
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime      @default(now())

  @@index([postId])
}

model PostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  gardenId  String?
  garden    Garden?  @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  type      String
  payload   String
  createdAt DateTime @default(now())

  @@index([gardenId, createdAt])
  @@index([actorId])
}

enum GrowthStage {
  SEED
  SPROUT
  SEEDLING
  YOUNG_PLANT
  ESTABLISHED
  ANCIENT
}

enum BuddyTrait {
  RESILIENT
  SUN_SEEKER
  NIGHT_BLOOMER
  WILD
  TENDER
}

enum BuddyMood {
  THRIVING
  HAPPY
  CONTENT
  WILTING
  THIRSTY
  DORMANT
}

model Buddy {
  id                  String      @id @default(cuid())
  userId              String      @unique
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  speciesId           String      @default("monstera")
  trait               BuddyTrait  @default(RESILIENT)
  growthStage         GrowthStage @default(SEED)
  journeyCount        Int         @default(0)
  dewdrops            Int         @default(0)
  experiencePoints    Int         @default(0)
  bloomTokens         Int         @default(0)
  lastPerfectDayKey   String?
  sunlightToday       Int         @default(0)
  tasksToday          Int         @default(0)
  lastResetDate       DateTime?
  mood                BuddyMood   @default(HAPPY)
  lastTaskDate        DateTime?
  streakDays          Int         @default(0)
  longestStreak       Int         @default(0)
  lastActiveDate      DateTime?
  equippedItems       Json        @default("{}")
  unlockedSpecies     Json        @default("[\"monstera\"]")
  currentBiome        String      @default("seed_garden")
  unlockedBiomes      Json        @default("[\"seed_garden\"]")
  personalityChoices  Json        @default("[]")
  terrariumLayout     Json        @default("{}")
  terrariumBackground String      @default("sunny_windowsill")
  floatingCompanionMode String    @default("hidden")
  gardenCode          String      @unique
  showLastActive      Boolean     @default(true)
  journeys            BuddyJourney[]
  inventory           BuddyInventory[]
  activities          BuddyActivity[]
  questProgress       BuddyQuestProgress[]
  challengeProgress   BuddyChallengeProgress[]
  friendshipsFrom     BuddyFriendship[] @relation("FriendshipFrom")
  friendshipsTo       BuddyFriendship[] @relation("FriendshipTo")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model BuddyJourney {
  id                   String    @id @default(cuid())
  buddyId              String
  buddy                Buddy     @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  biomeId              String
  startedAt            DateTime  @default(now())
  endsAt               DateTime
  completedAt          DateTime?
  completed            Boolean   @default(false)
  discoveryId          String?
  choiceMade           Int?
  dewdropsEarned       Int       @default(0)
  itemDropped          String?
  companionDropped     String?
  tasksCompletedDuring Int       @default(0)
  minutesSaved         Int       @default(0)

  @@index([buddyId, completed])
}

enum ItemCategory {
  HAT
  TOP
  SHOES
  GLASSES
  HELD_ITEM
  POT_SKIN
  BODY_COLOR
  BODY_PATTERN
  COMPANION
  WINGS
  BACKGROUND
  FURNITURE
}

enum ItemUnlockType {
  PURCHASE
  QUEST_REWARD
  JOURNEY_DROP
  ACHIEVEMENT
  SEASONAL_EVENT
  SPECIES_UNLOCK
  DEFAULT_ITEM
}

enum BuddySpeciesUnlockType {
  DEFAULT
  DEWDROPS
  STREAK
  QUEST
  JOURNEY_COUNT
  LEVEL
  SEASONAL
}

model ShopItem {
  id              String         @id
  name            String
  description     String
  category        ItemCategory
  tier            Int
  cost            Int
  bloomTokenCost  Int            @default(0)
  seasonalEventId String?
  requiresPremium Boolean        @default(false)
  speciesLocked   String?
  unlockType      ItemUnlockType @default(PURCHASE)
  imageKey        String
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  inventory       BuddyInventory[]
}

model BuddyInventory {
  id            String   @id @default(cuid())
  buddyId       String
  buddy         Buddy    @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  itemId        String
  item          ShopItem @relation(fields: [itemId], references: [id])
  acquiredAt    DateTime @default(now())
  acquireMethod String

  @@unique([buddyId, itemId])
}

model BuddySpecies {
  id          String                 @id
  displayName String
  description String
  emoji       String
  unlockType  BuddySpeciesUnlockType @default(DEFAULT)
  unlockValue Int?
  isDefault   Boolean                @default(false)
  sortOrder   Int                    @default(0)
}

enum ActivityType {
  WATERING_CHECK
  SUNLIGHT_AUDIT
  PEST_INSPECTION
  PLANT_JOURNAL
  REPOTTING_GUIDE
  SEASON_CHECK
  PROGRESS_PHOTO
  HUMIDITY_CHECK
  PRUNING_GUIDE
  PROPAGATION_LOG
}

enum QuestType {
  DAILY
  MONTHLY_CHALLENGE
  ACHIEVEMENT
  SEASONAL_EVENT
  FRIENDSHIP
}

model BuddyActivity {
  id              String       @id @default(cuid())
  buddyId         String
  buddy           Buddy        @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  userId          String
  activityType    ActivityType
  completedAt     DateTime     @default(now())
  durationSeconds Int?
  sunlightEarned  Int
  dewdropsEarned  Int
  taskId          String?
  journalEntryId  String?
  diagnosisId     String?
  plantId         String?
  notes           String?

  @@index([buddyId, completedAt])
}

model Quest {
  id             String     @id
  type           QuestType
  title          String
  description    String
  requirement    Json
  rewardDewdrops Int
  rewardItemId   String?
  rewardBadgeId  String?
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  progress       BuddyQuestProgress[]
}

model BuddyQuestProgress {
  id            String    @id @default(cuid())
  buddyId       String
  buddy         Buddy     @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  questId       String
  quest         Quest     @relation(fields: [questId], references: [id])
  progress      Int       @default(0)
  completed     Boolean   @default(false)
  completedAt   DateTime?
  rewardClaimed Boolean   @default(false)
  updatedAt     DateTime  @updatedAt

  @@unique([buddyId, questId])
}

model MonthlyChallenge {
  id             String   @id @default(cuid())
  month          Int
  year           Int
  title          String
  description    String
  steps          Json
  rewardDewdrops Int
  rewardItemId   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  progress       BuddyChallengeProgress[]

  @@unique([month, year])
}

model BuddyChallengeProgress {
  id               String           @id @default(cuid())
  buddyId          String
  buddy            Buddy            @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  challengeId      String
  challenge        MonthlyChallenge @relation(fields: [challengeId], references: [id])
  stepsCompleted   Int              @default(0)
  completedStepIds Json             @default("[]")
  completedAt      DateTime?
  startedAt        DateTime         @default(now())

  @@unique([buddyId, challengeId])
}

model BuddyFriendship {
  id                 String    @id @default(cuid())
  fromBuddyId        String
  toBuddyId          String
  fromBuddy          Buddy     @relation("FriendshipFrom", fields: [fromBuddyId], references: [id], onDelete: Cascade)
  toBuddy            Buddy     @relation("FriendshipTo", fields: [toBuddyId], references: [id], onDelete: Cascade)
  level              Int       @default(1)
  points             Int       @default(0)
  lastSunshineSentAt DateTime?
  totalSunshineSent  Int       @default(0)
  connectedAt        DateTime  @default(now())
  isActive           Boolean   @default(true)

  @@unique([fromBuddyId, toBuddyId])
  @@index([toBuddyId])
}

model SunshineEvent {
  id              String   @id @default(cuid())
  fromUserId      String
  toUserId        String
  fromBuddyId     String
  toBuddyId       String
  sentAt          DateTime @default(now())
  dewdropsAwarded Int      @default(3)

  @@index([toUserId, sentAt])
  @@index([fromUserId, sentAt])
}
