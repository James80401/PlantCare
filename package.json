{
  "name": "plant-care",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @plant-care/api",
    "dev:web": "npm run dev -w @plant-care/web --",
    "test:integrations": "node scripts/test-integrations.mjs",
    "dev:auth-help": "node scripts/dev-auth-help.mjs",
    "verify": "node scripts/verify.mjs",
    "smoke:buddy": "node scripts/smoke-buddy.mjs",
    "mobile:push-check": "node scripts/mobile-push-check.mjs",
    "verify:docs": "node scripts/verify-docs-links.mjs",
    "uat:e2e": "playwright test",
    "species:verify": "tsx scripts/verify-species-catalog.mjs",
    "species:photos:fetch": "node apps/api/scripts/fetch-species-photo-sources.mjs",
    "species:photos:download": "node apps/api/scripts/download-species-photos.mjs",
    "species:photos": "npm run species:photos:fetch && npm run species:photos:download",
    "species:photos:sync-missing": "node apps/api/scripts/sync-missing-species-photos.mjs",
    "species:photos:verify": "node scripts/verify-species-photos.mjs",
    "species:photos:list-missing": "node scripts/list-missing-species-photos.mjs",
    "build": "npm run build -w @plant-care/shared && npm run build -w @plant-care/api && npm run build -w @plant-care/web",
    "mobile:copy": "npm run mobile:copy -w @plant-care/web",
    "mobile:sync": "npm run mobile:sync -w @plant-care/web",
    "mobile:add:android": "npm run mobile:add:android -w @plant-care/web",
    "mobile:add:ios": "npm run mobile:add:ios -w @plant-care/web",
    "mobile:android": "npm run mobile:android -w @plant-care/web",
    "mobile:ios": "npm run mobile:ios -w @plant-care/web",
    "test": "npm run test -w @plant-care/api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate:postgres": "prisma generate --schema=prisma/schema.postgresql.prisma",
    "docker:build": "powershell -ExecutionPolicy Bypass -File scripts/docker-build.ps1",
    "docker:postgres": "docker compose up -d",
    "staging:up": "docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml down",
    "staging:check": "node scripts/check-staging-env.mjs",
    "staging:smoke": "powershell -ExecutionPolicy Bypass -File scripts/deploy-staging.ps1",
    "production:check": "powershell -ExecutionPolicy Bypass -File scripts/deploy-production-check.ps1",
    "production:check:env": "node scripts/check-production-env.mjs",
    "production:up": "docker compose -f docker-compose.production.yml --env-file .env.production up -d --build",
    "production:down": "docker compose -f docker-compose.production.yml down",
    "mobile:release:android": "npm run build -w @plant-care/web && npm run mobile:sync -w @plant-care/web && npm run mobile:android"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0"
  }
}
