{
  "name": "plant-care",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @plant-care/api",
    "dev:web": "npm run dev -w @plant-care/web --",
    "test:integrations": "node scripts/test-integrations.mjs",
    "build": "npm run build -w @plant-care/shared && npm run build -w @plant-care/api && npm run build -w @plant-care/web",
    "mobile:copy": "npm run mobile:copy -w @plant-care/web",
    "mobile:sync": "npm run mobile:sync -w @plant-care/web",
    "mobile:add:android": "npm run mobile:add:android -w @plant-care/web",
    "mobile:add:ios": "npm run mobile:add:ios -w @plant-care/web",
    "mobile:android": "npm run mobile:android -w @plant-care/web",
    "mobile:ios": "npm run mobile:ios -w @plant-care/web",
    "test": "npm run test -w @plant-care/api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0"
  }
}
